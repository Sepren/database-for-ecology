# Скопируйте в .env и подставьте свои значения.
# Файл .env не коммитится в Git.
#
# Docker Compose подставляет POSTGRES_* из этого файла в сервисы db и app.
# Один пароль для обоих — иначе приложение на http://localhost:8501 не подключится к БД.
# Если том БД уже создан со старым паролем, см. README: ALTER USER или docker compose down -v.

# PostgreSQL (имена совместимы с docker-compose)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=diploma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Альтернативные имена (поддерживаются в core/config.py)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=diploma
# DB_USER=postgres
# DB_PASSWORD=postgres
